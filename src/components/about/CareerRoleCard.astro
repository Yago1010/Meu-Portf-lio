---
type CareerRole = {
	period: string;
	role: string;
	focus: string;
	responsibilities: string[];
};

type Props = {
	item: CareerRole;
};

const { item } = Astro.props as Props;
---

<article class="career-card card-hover-lift">
	<p class="period">{item.period}</p>
	<h3>{item.role}</h3>
	<p class="focus">{item.focus}</p>
	<ul>
		{item.responsibilities.map((responsibility) => <li>{responsibility}</li>)}
	</ul>
</article>

<style>
	.career-card {
		padding: 1rem;
		border-radius: 14px;
		border: 1px solid var(--border);
		background: linear-gradient(180deg, rgba(12, 20, 33, 0.95), rgba(7, 14, 24, 0.95));
	}
	.period {
		margin: 0;
		color: var(--accent);
		font-size: 0.78rem;
		text-transform: uppercase;
		font-weight: 800;
		letter-spacing: 0.06em;
	}
	h3 {
		margin: 0.35rem 0 0.25rem;
	}
	.focus {
		margin: 0;
		color: #c4d8f6;
		font-size: 0.92rem;
	}
	ul {
		margin: 0.75rem 0 0;
		padding-left: 1.05rem;
		display: grid;
		gap: 0.35rem;
	}
	li {
		color: var(--muted);
		font-size: 0.9rem;
	}
</style>
