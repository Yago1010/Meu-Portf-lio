<div class="three-wrap">
	<canvas id="hero-three-canvas" aria-label="Cena 3D decorativa"></canvas>
</div>

<script type="module">
	import * as THREE from 'three';

	const canvas = document.getElementById('hero-three-canvas');
	if (!(canvas instanceof HTMLCanvasElement)) {
		throw new Error('Canvas do hero 3D não encontrado.');
	}

	const scene = new THREE.Scene();
	const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
	renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.8));

	const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 100);
	camera.position.set(0, 0.4, 5.8);

	const ambient = new THREE.AmbientLight(0xffffff, 0.35);
	scene.add(ambient);

	const keyLight = new THREE.PointLight(0x76c6ff, 1.7, 18);
	keyLight.position.set(3.6, 3, 4);
	scene.add(keyLight);

	const rimLight = new THREE.PointLight(0x356dff, 1.25, 14);
	rimLight.position.set(-3, -1.2, -1.5);
	scene.add(rimLight);

	const coreGeometry = new THREE.IcosahedronGeometry(1.1, 1);
	const coreMaterial = new THREE.MeshStandardMaterial({
		color: 0xdce9ff,
		metalness: 0.22,
		roughness: 0.28,
		flatShading: true,
	});
	const core = new THREE.Mesh(coreGeometry, coreMaterial);
	scene.add(core);

	const wireGeometry = new THREE.IcosahedronGeometry(1.7, 1);
	const wireMaterial = new THREE.MeshBasicMaterial({
		color: 0x67b4ff,
		wireframe: true,
		transparent: true,
		opacity: 0.5,
	});
	const shell = new THREE.Mesh(wireGeometry, wireMaterial);
	scene.add(shell);

	const particleCount = 420;
	const pointsGeometry = new THREE.BufferGeometry();
	const positions = new Float32Array(particleCount * 3);
	for (let i = 0; i < particleCount * 3; i += 3) {
		const radius = 2.3 + Math.random() * 1.9;
		const theta = Math.random() * Math.PI * 2;
		const phi = Math.acos((Math.random() * 2) - 1);
		positions[i] = radius * Math.sin(phi) * Math.cos(theta);
		positions[i + 1] = radius * Math.cos(phi) * 0.7;
		positions[i + 2] = radius * Math.sin(phi) * Math.sin(theta);
	}
	pointsGeometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));

	const pointsMaterial = new THREE.PointsMaterial({
		color: 0x8ac1ff,
		size: 0.03,
		sizeAttenuation: true,
		transparent: true,
		opacity: 0.9,
	});
	const points = new THREE.Points(pointsGeometry, pointsMaterial);
	scene.add(points);

	let targetRotationY = 0;
	let targetRotationX = 0;

	const onPointerMove = (event) => {
		const x = (event.clientX / window.innerWidth) * 2 - 1;
		const y = (event.clientY / window.innerHeight) * 2 - 1;
		targetRotationY = x * 0.22;
		targetRotationX = y * 0.12;
	};
	window.addEventListener('pointermove', onPointerMove);

	const resize = () => {
		const rect = canvas.getBoundingClientRect();
		const width = Math.max(rect.width, 280);
		const height = Math.max(rect.height, 280);
		renderer.setSize(width, height, false);
		camera.aspect = width / height;
		camera.updateProjectionMatrix();
	};
	resize();
	window.addEventListener('resize', resize);

	let raf = 0;
	const clock = new THREE.Clock();
	const animate = () => {
		const t = clock.getElapsedTime();
		core.rotation.y += 0.004;
		core.rotation.x += 0.002;

		core.rotation.y += (targetRotationY - core.rotation.y) * 0.02;
		core.rotation.x += (targetRotationX - core.rotation.x) * 0.015;
		shell.rotation.y = -core.rotation.y * 0.8;
		shell.rotation.x = core.rotation.x * 0.6;

		points.rotation.y = t * 0.04;
		points.rotation.x = Math.sin(t * 0.4) * 0.05;
		core.position.y = Math.sin(t * 0.9) * 0.09;
		shell.position.y = core.position.y * 0.8;

		renderer.render(scene, camera);
		raf = window.requestAnimationFrame(animate);
	};
	animate();

	const mediaQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
	if (mediaQuery.matches) {
		window.cancelAnimationFrame(raf);
		renderer.render(scene, camera);
	}

	window.addEventListener('beforeunload', () => {
		window.cancelAnimationFrame(raf);
		window.removeEventListener('resize', resize);
		window.removeEventListener('pointermove', onPointerMove);
		coreGeometry.dispose();
		coreMaterial.dispose();
		wireGeometry.dispose();
		wireMaterial.dispose();
		pointsGeometry.dispose();
		pointsMaterial.dispose();
		renderer.dispose();
	});
</script>

<style>
	.three-wrap {
		border-radius: 24px;
		border: 1px solid var(--border);
		background: radial-gradient(circle at 20% 20%, rgba(115, 191, 255, 0.18), transparent 55%),
			radial-gradient(circle at 75% 80%, rgba(43, 99, 255, 0.2), transparent 50%),
			var(--surface);
		min-height: 420px;
		height: 100%;
		overflow: hidden;
	}

	#hero-three-canvas {
		width: 100%;
		height: 100%;
		min-height: 420px;
		display: block;
	}

	@media (max-width: 980px) {
		.three-wrap,
		#hero-three-canvas {
			min-height: 320px;
		}
	}
</style>
