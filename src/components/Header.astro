---
import { withBase } from '../lib/paths';
import site from '../data/site.json';
import type { SiteData } from '../types/content';

const data = site as SiteData;
const nav = [
	{ href: withBase(''), label: 'Home' },
	{ href: withBase('archive'), label: 'Archive' },
	{ href: withBase('projetos'), label: 'Portfólio' },
	{ href: withBase('especialidades/frontend'), label: 'Frontend', mobileOnly: true },
	{ href: withBase('especialidades/mobile'), label: 'Mobile', mobileOnly: true },
	{ href: withBase('sobre'), label: 'Sobre' },
	{ href: withBase('contato'), label: 'Contato' },
];
---

<header class="header-shell">
	<div class="header-container">
		<a href={withBase('')} class="brand">
			<span>{data.profile.name}</span>
			<small>{data.profile.headline}</small>
		</a>
		<button class="mobile-trigger" type="button" aria-expanded="false" aria-controls="main-menu">
			<span class="sr-only">Abrir menu</span>
			<span></span>
			<span></span>
			<span></span>
		</button>
		<nav aria-label="Principal" id="main-menu">
			<ul class="nav-list">
				{nav.map(({ href, label, mobileOnly }) => (
					<li class={mobileOnly ? 'mobile-only-item' : ''}>
						<a href={href}>{label}</a>
					</li>
				))}
			</ul>
		</nav>
	</div>
	<script is:inline>
		const trigger = document.querySelector('.mobile-trigger');
		const menu = document.getElementById('main-menu');
		if (trigger && menu) {
			trigger.addEventListener('click', () => {
				const opened = menu.classList.toggle('is-open');
				trigger.setAttribute('aria-expanded', opened ? 'true' : 'false');
				document.body.classList.toggle('menu-open', opened);
			});
			menu.querySelectorAll('a').forEach((link) => {
				link.addEventListener('click', () => {
					menu.classList.remove('is-open');
					trigger.setAttribute('aria-expanded', 'false');
					document.body.classList.remove('menu-open');
				});
			});
		}
	</script>
</header>

<style>
	.header-shell {
		position: sticky;
		top: 0;
		z-index: 30;
		background: color-mix(in srgb, var(--bg) 82%, transparent);
		backdrop-filter: blur(14px);
		border-bottom: 1px solid color-mix(in srgb, var(--border) 75%, #ffffff 25%);
	}
	.header-container {
		max-width: var(--max);
		margin: 0 auto;
		padding: 0.85rem 1.5rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}
	.brand {
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
		color: var(--text);
		text-decoration: none;
	}
	.brand span {
		font-weight: 800;
	}
	.brand small {
		font-size: 0.75rem;
		color: var(--muted);
	}
	.nav-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		gap: 0.28rem;
	}
	.nav-list a {
		display: inline-flex;
		padding: 0.4rem 0.75rem;
		border-radius: 999px;
		color: var(--muted);
		text-decoration: none;
		font-weight: 700;
		font-size: 0.86rem;
	}
	.nav-list a:hover {
		background: var(--surface);
		color: var(--text);
	}
	.mobile-only-item {
		display: none;
	}
	.mobile-trigger {
		display: none;
		width: 2.6rem;
		height: 2.6rem;
		border-radius: 999px;
		border: 1px solid color-mix(in srgb, var(--border) 55%, #ffffff 45%);
		background: linear-gradient(180deg, color-mix(in srgb, var(--surface) 90%, #ffffff 10%), var(--surface));
		padding: 0.5rem;
		gap: 0.18rem;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		cursor: pointer;
		box-shadow: 0 7px 18px rgba(0, 0, 0, 0.2);
	}
	.mobile-trigger span:not(.sr-only) {
		display: block;
		width: 1rem;
		height: 2px;
		background: var(--text);
		border-radius: 99px;
	}
	@media (max-width: 700px) {
		.brand small {
			display: none;
		}
		.header-container {
			padding: 0.7rem 1rem;
			display: grid;
			grid-template-columns: 1fr auto;
			align-items: center;
		}
		.mobile-trigger {
			display: flex;
		}
		.mobile-only-item {
			display: block;
		}
		nav {
			grid-column: 1 / -1;
			width: 100%;
			display: none;
			padding-top: 0.6rem;
			animation: menuDrop 0.2s ease;
		}
		nav.is-open {
			display: block;
		}
		.nav-list {
			flex-direction: column;
			gap: 0.35rem;
			width: 100%;
		}
		.nav-list li,
		.nav-list a {
			width: 100%;
		}
		.nav-list a {
			border: 1px solid var(--border);
			background: var(--surface);
		}
	}
	@keyframes menuDrop {
		from {
			opacity: 0;
			transform: translateY(-6px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
</style>
