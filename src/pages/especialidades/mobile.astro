---
import BaseLayout from '../../layouts/BaseLayout.astro';
import projects from '../../data/projects.json';
import type { Project } from '../../types/content';
import PageIntro from '../../components/ui/PageIntro.astro';
import MobileProjectCard from '../../components/specialties/MobileProjectCard.astro';

const mobileProjects = (projects as Project[]).filter((project) => project.category === 'Mobile').slice(0, 12);
const specialties = [
	{
		title: 'Desenvolvimento Android',
		description:
			'Desenvolvimento de aplicativos nativos e multiplataforma para Android usando Java, Kotlin e práticas modernas de UI/UX.',
	},
	{
		title: 'Desenvolvimento Flutter',
		description:
			'Criação de aplicações multiplataforma escaláveis com arquitetura orientada a estado, integrações nativas e foco em experiência.',
	},
	{
		title: 'Integração de API RESTful e GraphQL',
		description:
			'Conexão de apps com APIs seguras, cache inteligente e sincronização em tempo real para máxima confiabilidade.',
	},
	{
		title: 'Firebase e serviços em nuvem',
		description:
			'Autenticação, Firestore, banco em tempo real, notificações e monitoramento para apps móveis escaláveis.',
	},
	{
		title: 'Integração de gateway de pagamento',
		description:
			'Pagamentos com Stripe, Apple Pay, Google Pay e compras in-app com validações adequadas e seguras.',
	},
	{
		title: 'Processamento e transmissão de vídeo',
		description:
			'Soluções avançadas com FFmpeg, players customizados e Agora SDK para comunicação em tempo real.',
	},
	{
		title: 'Integrações de IA e TensorFlow',
		description:
			'Funcionalidades com aprendizado de máquina e reconhecimento de dados otimizados para dispositivos móveis.',
	},
	{
		title: 'Comunicação em tempo real',
		description:
			'Integração com WebSockets e Pusher para chat, eventos em tempo real e colaboração.',
	},
	{
		title: 'Serviços de localização e mapas',
		description:
			'Navegação, rastreamento em tempo real e soluções baseadas em localização com Google Maps.',
	},
];
---

<BaseLayout title="Especialidade Mobile" description="Portfólio e especialidades focadas em desenvolvimento mobile.">
	<PageIntro
		eyebrow="Especialidade"
		title="Mobile"
		description="Página dedicada para projetos e capacidades mobile, com cards mais consistentes e imagens alinhadas."
	/>

	<section class="section mobile-showcase">
		<h2>Portfólio mobile</h2>
		<div class="showcase-grid">
			{mobileProjects.map((project) => <MobileProjectCard project={project} />)}
		</div>
	</section>

	<section class="section specialties-grid">
		<h2>Habilidades e conhecimentos técnicos</h2>
		<div class="cards-grid">
			{specialties.map((item) => (
				<article class="specialty-card">
					<h3>{item.title}</h3>
					<p>{item.description}</p>
				</article>
			))}
		</div>
	</section>
</BaseLayout>

<style>
	.section {
		margin-top: 2.5rem;
	}
	.mobile-showcase,
	.specialties-grid {
		border: 1px solid var(--border);
		background: linear-gradient(180deg, rgba(6, 18, 36, 0.95), rgba(5, 13, 26, 0.98));
		border-radius: 16px;
		padding: 1.4rem;
	}
	h2 {
		margin-top: 0;
	}
	.showcase-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.9rem;
	}
	.cards-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.8rem;
	}
	.specialty-card {
		border-radius: 12px;
		border: 1px solid rgba(48, 136, 226, 0.3);
		background: rgba(4, 16, 34, 0.9);
		padding: 1rem;
	}
	.specialty-card h3 {
		margin: 0 0 0.5rem;
		font-size: 1rem;
	}
	.specialty-card p {
		margin: 0;
		color: #adc6e7;
		font-size: 0.9rem;
	}
	@media (max-width: 900px) {
		.showcase-grid,
		.cards-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}
	@media (max-width: 620px) {
		.showcase-grid,
		.cards-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
