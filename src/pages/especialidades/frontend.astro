---
import BaseLayout from '../../layouts/BaseLayout.astro';
import projects from '../../data/projects.json';
import type { Project } from '../../types/content';
import PageIntro from '../../components/ui/PageIntro.astro';
import FrontendProjectCard from '../../components/specialties/FrontendProjectCard.astro';

const frontendProjects = (projects as Project[]).filter((project) => project.category !== 'Mobile').slice(0, 12);
const capabilities = [
	'Design systems escaláveis e padronização de UI',
	'Arquitetura frontend com foco em performance e DX',
	'Integração com APIs complexas e observabilidade',
	'Acessibilidade, SEO técnico e métricas Core Web Vitals',
];
---

<BaseLayout title="Especialidade Frontend" description="Portfólio e especialidades focadas em frontend e web.">
	<PageIntro
		eyebrow="Especialidade"
		title="Frontend"
		description="Interfaces profissionais orientadas a produto, performance, conversão e experiência do usuário."
	/>

	<section class="section capability-panel">
		<h2>Diferenciais de entrega</h2>
		<div class="capability-list">
			{capabilities.map((item) => <p>{item}</p>)}
		</div>
	</section>

	<section class="section frontend-archive">
		<h2>Projetos frontend</h2>
		<div class="frontend-grid">
			{frontendProjects.map((project) => <FrontendProjectCard project={project} />)}
		</div>
	</section>
</BaseLayout>

<style>
	.section {
		margin-top: 2.5rem;
	}
	.capability-panel {
		border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--border));
		border-radius: 16px;
		background: linear-gradient(180deg, rgba(8, 17, 31, 0.96), rgba(8, 15, 25, 0.96));
		padding: 1.2rem 1.3rem;
	}
	.capability-panel h2 {
		margin: 0 0 0.75rem;
		font-size: 1.08rem;
	}
	.capability-list {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.65rem;
	}
	.capability-list p {
		margin: 0;
		border-radius: 10px;
		border: 1px solid var(--border);
		background: rgba(6, 14, 24, 0.8);
		padding: 0.65rem 0.75rem;
		color: #c7dcfb;
		font-size: 0.9rem;
	}
	.frontend-archive {
		border: 1px solid var(--border);
		border-radius: 16px;
		padding: 1.4rem 1.1rem;
		background: linear-gradient(180deg, rgba(7, 16, 29, 0.96), rgba(7, 13, 24, 0.96));
	}
	.frontend-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.9rem;
	}
	@media (max-width: 760px) {
		.capability-list,
		.frontend-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
